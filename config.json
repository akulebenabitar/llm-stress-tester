{
  "endpoint": "http://localhost:1234/v1",
  "api_key": "lm-studio",
  "max_test_duration_seconds": 300,
  "tests": {
    "context_window": {
      "enabled": true,
      "min_tokens": 100,
      "max_tokens": 500000,
      "step_tokens": 2000,
      "requests_per_size": 2,
      "max_test_points": 50
    },
    "rate_limit_burst": {
      "enabled": true,
      "duration_seconds": 30,
      "target_rps": 20,
      "max_concurrent": 16
    },
    "rate_limit_sustained": {
      "enabled": true,
      "duration_seconds": 60,
      "target_rps": 10,
      "max_concurrent": 8
    },
    "parallelism": {
      "enabled": true,
      "max_workers": 32,
      "requests_per_worker": 3,
      "shared_memory": false,
      "shared_memory_turns": 5
    },
    "streaming": {
      "enabled": true,
      "num_requests": 10,
      "max_tokens": 256
    },
    "error_handling": {
      "enabled": true,
      "num_invalid_requests": 6
    },
    "memory_stability": {
      "enabled": true,
      "duration_seconds": 1800,
      "requests_per_minute": 30
    },
    "gpu_monitoring": {
      "enabled": true
    },
    "deliberation": {
      "enabled": true,
      "num_turns": 20,
      "topic": "Should our company invest in artificial intelligence research?",
      "adversarial_turns": 5,
      "context_switch_turns": 3
    }
  },
  "output": {
    "save_json": true,
    "save_csv": true,
    "verbose": true
  }
}